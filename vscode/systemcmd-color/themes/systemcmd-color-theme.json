{
  "name": "systemcmd color",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1d1d1d",
    "editor.foreground": "#d1d1d1",
    "editorLineNumber.foreground": "#7e7e7e",
    "editorLineNumber.activeForeground": "#d1d1d1",
    "editorCursor.foreground": "#5ac8ff",
    "editor.selectionBackground": "#2f2f2f",
    "editor.lineHighlightBackground": "#242424",
    "editorIndentGuide.background1": "#242424",
    "editorIndentGuide.activeBackground1": "#2f2f2f",
    "editorWidget.background": "#171717",
    "editorWidget.border": "#2f2f2f",
    "sideBar.background": "#171717",
    "sideBar.foreground": "#d1d1d1",
    "activityBar.background": "#171717",
    "activityBar.foreground": "#d1d1d1",
    "titleBar.activeBackground": "#171717",
    "titleBar.activeForeground": "#d1d1d1",
    "statusBar.background": "#171717",
    "statusBar.foreground": "#d1d1d1",
    "panel.background": "#1d1d1d",
    "panel.border": "#2f2f2f",
    "terminal.background": "#1d1d1d",
    "terminal.foreground": "#d1d1d1",
    "terminalCursor.foreground": "#5ac8ff",
    "terminal.ansiBlack": "#1d1d1d",
    "terminal.ansiBlue": "#5c78ff",
    "terminal.ansiCyan": "#5ac8ff",
    "terminal.ansiGreen": "#5effc3",
    "terminal.ansiMagenta": "#ff5eed",
    "terminal.ansiRed": "#d35454",
    "terminal.ansiWhite": "#d1d1d1",
    "terminal.ansiYellow": "#d38454",
    "terminal.ansiBrightBlack": "#7e7e7e",
    "terminal.ansiBrightBlue": "#5c78ff",
    "terminal.ansiBrightCyan": "#5ac8ff",
    "terminal.ansiBrightGreen": "#5effc3",
    "terminal.ansiBrightMagenta": "#ba5aff",
    "terminal.ansiBrightRed": "#d35454",
    "terminal.ansiBrightWhite": "#d1d1d1",
    "terminal.ansiBrightYellow": "#d38454"
  },
  "semanticTokenColors": {
    "enumMember": {
      "foreground": "#d1d1d1"
    },
    "variable.constant": {
      "foreground": "#5effc3"
    },
    "variable.defaultLibrary": {
      "foreground": "#d1d1d1"
    }
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "name": "Comments",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6f7480"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "name": "Keywords",
      "settings": {
        "foreground": "#ff5eed"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "name": "Strings",
      "settings": {
        "foreground": "#ba5aff"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "name": "Numbers and Constants",
      "settings": {
        "foreground": "#5effc3"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "name": "Functions",
      "settings": {
        "foreground": "#5ac8ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type"
      ],
      "name": "Types",
      "settings": {
        "foreground": "#d1d1d1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "name": "Variables",
      "settings": {
        "foreground": "#5c78ff"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "name": "Parameters",
      "settings": {
        "foreground": "#d1d1d1"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "name": "Punctuation",
      "settings": {
        "foreground": "#d1d1d1"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "name": "Invalid",
      "settings": {
        "foreground": "#d35454"
      }
    }
  ]
}
